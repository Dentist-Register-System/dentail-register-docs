# Register System — deploy secrets (EXAMPLE / key names only).
#
# Copy this to the REAL file, which lives OUTSIDE every git repo so it can never be committed:
#   cp docs/ops/deploy.env.example ~/Documents/register_workspace/.register-ops.env
#   chmod 600 ~/Documents/register_workspace/.register-ops.env
# Then fill in the values. deploy.sh sources that file (never this one).
# Account/OAuth logins are NOT here — you run `vercel login` / `render login` interactively.

# ---- Domains ----
FRONTEND_DOMAIN=register.rohan2jos.com
BACKEND_DOMAIN=api.rohan2jos.com
FRONTEND_SUB=register
BACKEND_SUB=api

# ---- Frontend (Vercel) env — pushed to Production + Preview ----
NEXT_PUBLIC_API_BASE_URL=https://api.rohan2jos.com
NEXT_PUBLIC_SUPABASE_URL=https://wxwasnshmnttiixvzeod.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=        # Supabase → Project Settings → API → Publishable/anon key
VERCEL_PROJECT_DIR=/Users/rohanjoshi/Documents/register_workspace/dentist-registry-frontend

# ---- Cloudflare DNS (scoped token: Zone:DNS:Edit on rohan2jos.com ONLY) ----
CF_API_TOKEN=                                 # Cloudflare → My Profile → API Tokens → Create (DNS edit, this zone)
CF_ZONE_ID=                                   # Cloudflare → rohan2jos.com → Overview → Zone ID
CF_ZONE_NAME=rohan2jos.com
VERCEL_CNAME_TARGET=                          # value Vercel shows when you add the domain (e.g. cname.vercel-dns.com)
RENDER_CNAME_TARGET=                          # value Render shows for the custom domain (e.g. <svc>.onrender.com)

# ---- Hook tick (must equal HOOK_TICK_SECRET set on Render) ----
HOOK_TICK_SECRET=                             # strong random; e.g. `openssl rand -hex 24`

# ---- cron-job.org ----
CRONJOB_API_KEY=                              # cron-job.org → Settings → API

# ---- Backend (Render) secrets are set on Render, NOT here (sync:false in render.yaml):
#   DATABASE_URL (Supabase pooler), HOOK_TICK_SECRET (same value as above),
#   RESEND_API_KEY (optional). See deploy-runbook.md.
